const chords = "<F>";
const scales = cat('C minor','C major');

stack(
  chords.rootNotes(4)
    .scale(scales)
    .struct("x(3,8,-2)".fast(2))
    .scaleTranspose("0 4 0 6".early(".125 .5"))
    .layer(scaleTranspose("0,<2 [4,6] [5,7]>/4"))
).slow(2)
  .velocity(sine.struct("x*8").add(3/5).mul(2/5).fast(8))
  .note()
  .pianoroll({labels: 1})
